{
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/about-us",
            "destination": "/about-us.html"
        },
        {
            "source": "/what-we-do",
            "destination": "/what-we-do.html"
        },
        {
            "source": "/who-we-are",
            "destination": "/who-we-are.html"
        },
        {
            "source": "/careers",
            "destination": "/careers/index.html"
        },
        {
            "source": "/agency",
            "destination": "/agency/index.html"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}