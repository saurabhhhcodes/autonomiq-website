{
  "schema_version": "latest",
  "name": "Web Development Teaching",
  "description": "Interactive web development teaching configuration",
  "metadata": {
    "parameters": {
      "student_level": "beginner",
      "focus_area": "frontend"
    }
  },
  "prompts": [
    {
      "name": "explain_html",
      "input": "Explain HTML {{element}} to a {{student_level}} student. Include code examples and practical use cases.",
      "metadata": {
        "model": {
          "name": "gemini-pro",
          "settings": {
            "temperature": 0.6,
            "max_output_tokens": 700
          }
        },
        "parameters": {
          "element": "basics",
          "student_level": "beginner"
        }
      }
    },
    {
      "name": "debug_code",
      "input": "Help debug this {{language}} code: {{code}}. Explain what's wrong and provide the corrected version.",
      "metadata": {
        "model": {
          "name": "gemini-pro",
          "settings": {
            "temperature": 0.4,
            "max_output_tokens": 600
          }
        },
        "parameters": {
          "language": "JavaScript",
          "code": "console.log('Hello World')"
        }
      }
    },
    {
      "name": "project_guidance",
      "input": "Guide a {{student_level}} student to build a {{project_type}} project. Provide step-by-step instructions and best practices.",
      "metadata": {
        "model": {
          "name": "gemini-pro",
          "settings": {
            "temperature": 0.7,
            "max_output_tokens": 800
          }
        },
        "parameters": {
          "student_level": "beginner",
          "project_type": "todo app"
        }
      }
    }
  ]
}